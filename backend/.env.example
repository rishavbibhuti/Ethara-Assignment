# Copy to .env and adjust as needed.

# Default is local SQLite (zero setup). For PostgreSQL use e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/seat_allocation
DATABASE_URL=sqlite:///./seat_allocation.db

# Comma-separated list of allowed frontend origins. Use * for all (dev only).
CORS_ORIGINS=*

# Optional: enables LLM-assisted natural-language queries in the AI assistant.
# ANTHROPIC_API_KEY=sk-ant-...
